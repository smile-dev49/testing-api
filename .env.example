# --- Server ---
VIEW_API_HOST=0.0.0.0
VIEW_API_PORT=8093
LOG_LEVEL=INFO
CORS_ORIGINS=*
ENABLE_OPENAPI_DOCS=true

# --- MongoDB (view API /api/v1/view/*) ---
MONGODB_URL=mongodb://localhost:27017/rcs_parser

# --- PostgreSQL (master data /api/v1/master-data/*) ---
# Render.com: use DATABASE_URL
DATABASE_URL=postgresql://user:password@host:5432/dbname
# Or:
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=postgres
# PG_PASSWORD=
# PG_DATABASE=postgres

ENABLE_MASTER_DATA_APIS=true
# Optional: require X-API-Key header for all master-data routes
# MASTER_DATA_API_KEY=your_secret_key
